<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports 
                                  http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="RelatorioProdutos"
              pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20"
              uuid="a3c8c8f2-d1b6-4c28-8911-123456789abc">

    <!-- Campos -->
    <field name="nome" class="java.lang.String"/>
    <field name="estoque" class="java.lang.Integer"/>
    <field name="preco" class="java.math.BigDecimal"/>
    <field name="categoria" class="java.lang.String"/>

    <!-- Título -->
    <title>
        <band height="200">
            <!-- Logo -->
            <image>
                <reportElement x="210" y="0" width="300" height="120" />
                <imageExpression><![CDATA["src/main/resources/livraria_logo.png"]]></imageExpression>
            </image>

            <!-- Endereço -->
            <staticText>
                <reportElement x="0" y="130" width="555" height="15" />
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Livraria Arca da Aliança - R. Forte de Vila Bela, 62 - Jardim Iporã]]></text>
            </staticText>

            <!-- Contato -->
            <staticText>
                <reportElement x="0" y="150" width="555" height="15" />
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <text><![CDATA[Telefone: (11) 94197-9794 | Email: livrariaarcadaalianca@gmail.com]]></text>
            </staticText>

            <!-- Título -->
            <staticText>
                <reportElement x="0" y="170" width="555" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="14"/>
                </textElement>
                <text><![CDATA[Relatório de Produtos Cadastrados]]></text>
            </staticText>
        </band>
    </title>

    <!-- Cabeçalho da Tabela -->
    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="200" height="20" backcolor="#CCCCCC" mode="Opaque"/>
                <text><![CDATA[Nome do Produto]]></text>
            </staticText>
            <staticText>
                <reportElement x="200" y="0" width="100" height="20" backcolor="#CCCCCC" mode="Opaque"/>
                <text><![CDATA[Estoque]]></text>
            </staticText>
            <staticText>
                <reportElement x="300" y="0" width="100" height="20" backcolor="#CCCCCC" mode="Opaque"/>
                <text><![CDATA[Preço]]></text>
            </staticText>
            <staticText>
                <reportElement x="400" y="0" width="155" height="20" backcolor="#CCCCCC" mode="Opaque"/>
                <text><![CDATA[Categoria]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- Detalhes -->
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="200" height="20"/>
                <textFieldExpression><![CDATA[$F{nome}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="200" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[String.valueOf($F{estoque}) + " un"]]></textFieldExpression>
            </textField>
            <textField pattern="R$ #,##0.00">
                <reportElement x="300" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{preco}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="400" y="0" width="155" height="20"/>
                <textFieldExpression><![CDATA[$F{categoria}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>

